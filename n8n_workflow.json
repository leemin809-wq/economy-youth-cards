      "name": "Notion 자막 스타일 불러오기",
      "type": "n8n-nodes-base.notion",
      "position": [600, 500]
    },
    {
      "parameters": {
        "jsCode": "const rssItems = $('Google Alerts RSS 수집').all();\nconst prompt = $('Notion 활성 프롬프트 불러오기').first().json;\nconst tts = $('Notion TTS 템플릿 불러오기').first().json;\nconst subtitle = $('Notion 자막 스타일 불러오기').first().json;\n\nconst newsText = rssItems.slice(0, 3).map(i => {\n  return `제목: ${i.json.title}\\n내용: ${i.json.contentSnippet || ''}`;\n}).join('\\n\\n');\n\nconst promptText = prompt.properties['프롬프트 내용'].rich_text[0]?.plain_text || '';\nconst finalPrompt = promptText.replace('{{news_content}}', newsText);\n\nreturn [{\n  json: {\n    finalPrompt,\n    ttsVoice: tts.properties['목소리'].select?.name || 'SunHiNeural',\n    ttsSpeed: tts.properties['재생 속도'].rich_text[0]?.plain_text || '1.1',\n    ttsOpening: tts.properties['오프닝 문구'].rich_text[0]?.plain_text || '',\n    ttsClosing: tts.properties['클로징 문구'].rich_text[0]?.plain_text || '',\n    subtitleParams: subtitle.properties['FFmpeg 파라미터'].rich_text[0]?.plain_text || '',\n    usedPromptName: prompt.properties['프롬프트 이름'].title[0]?.plain_text || '기본',\n    today: new Date().toISOString().split('T')[0]\n  }\n}];"
      },
      "name": "데이터 병합 & 프롬프트 조립",
      "type": "n8n-nodes-base.code",
      "position": [820, 350]
    },
    {
      "parameters": {
        "url": "https://api.anthropic.com/v1/messages",
        "method": "POST",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            { "name": "x-api-key", "value": "={{ $env.ANTHROPIC_API_KEY }}" },
            { "name": "anthropic-version", "value": "2023-06-01" },
            { "name": "content-type", "value": "application/json" }
          ]
        },
        "sendBody": true,
        "bodyParameters": {
          "parameters": [
            { "name": "model", "value": "claude-sonnet-4-20250514" },
            { "name": "max_tokens", "value": "4096" },
            { "name": "messages", "value": "=[{\"role\":\"user\",\"content\":\"{{ $json.finalPrompt }}\\n\\n반드시 JSON만 출력하세요. 마크다운 없이 순수 JSON만.\"}]" }
          ]
        }
      },
      "name": "Claude API 콘텐츠 생성",
      "type": "n8n-nodes-base.httpRequest",
      "position": [1040, 350]
    },
    {
      "parameters": {
        "jsCode": "const response = $input.first().json;\nconst rawText = response.content[0].text;\n\nlet cardData;\ntry {\n  cardData = JSON.parse(rawText);\n} catch(e) {\n  const jsonMatch = rawText.match(/\\{[\\s\\S]*\\}/);\n  cardData = JSON.parse(jsonMatch[0]);\n}\n\nconst meta = $('데이터 병합 & 프롬프트 조립').first().json;\nconst fullTTSScript = `${meta.ttsOpening} ${cardData.tts_script} ${meta.ttsClosing}`;\n\nreturn [{\n  json: {\n    cardData,\n    ttsVoice: meta.ttsVoice,\n    ttsSpeed: parseFloat(meta.ttsSpeed),\n    fullTTSScript,\n    subtitleParams: meta.subtitleParams,\n    today: meta.today,\n    usedPromptName: meta.usedPromptName,\n    youtubeTitle: cardData.youtube_title || `경제청년 | ${cardData.topic}`,\n    hashtags: cardData.hashtags || {}\n  }\n}];"
      },
      "name": "JSON 파싱 & 데이터 정리",
      "type": "n8n-nodes-base.code",
      "position": [1260, 350]
    },
    {
      "parameters": {
